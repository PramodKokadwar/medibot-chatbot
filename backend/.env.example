# ── Cloud LLM (OpenAI) ──────────────────────────────────────────────────────
# Required for full LLM-generated answers. Leave blank to use local extractive fallback.
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── Qdrant (optional — leave blank to use in-memory retrieval) ──────────────
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=medibot_chunks

# ── Data paths ───────────────────────────────────────────────────────────────
# Relative paths from the backend/ directory, or absolute paths
DATA_DIR=../mediassist_data
SQLITE_DB_PATH=../mediassist_data/db/mediassist.db

# ── Feature flags ────────────────────────────────────────────────────────────
# Set to true to load sentence-transformers (dense embeddings) and
# cross-encoder (reranker) locally. Requires ~400 MB download on first run.
ENABLE_LOCAL_ML_MODELS=false

# Set to false to disable the extractive text fallback when no LLM key is set.
ALLOW_LOCAL_LLM_FALLBACK=true
